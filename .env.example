# Backend selection
MODEL_BACKEND=local_openai
EVALUATION_FRAMEWORK=classic

# Gemini backend (only needed if MODEL_BACKEND=gemini)
GOOGLE_API_KEY=
GENERATION_MODEL=gemini-2.5-flash-lite
EMBEDDING_MODEL=gemini-embedding-001

# Local OpenAI-compatible backend
LOCAL_LLM_API_KEY=local-dev-key
LOCAL_LLM_BASE_URL=http://127.0.0.1:8001/v1
LOCAL_GENERATION_MODEL=mistralai/Mistral-7B-Instruct-v0.3
LOCAL_GRAPHRAG_INDEX_MODEL=mistralai/Mistral-7B-Instruct-v0.3
LOCAL_EMBEDDING_MODEL=intfloat/e5-base-v2
LOCAL_SERVER_HOST=127.0.0.1
LOCAL_SERVER_PORT=8001
LOCAL_MAX_NEW_TOKENS=2048
LOCAL_MODEL_DEVICE=auto
LOCAL_MODEL_DEVICE_MAP=none
LOCAL_MODEL_TRUST_REMOTE_CODE=false

# Retrieval / experiment defaults
TOP_K_RETRIEVAL=5
FAIR_BASELINE_MAX_CONTEXT_CHARS=16000
FAIR_BASELINE_MAX_ANSWER_TOKENS=128
MAX_LINKED_PASSAGES=3

# GraphRAG local search tuning
GRAPHRAG_LOCAL_REPORT_COMMUNITY_LEVEL=2
GRAPHRAG_LOCAL_COMMUNITY_PROP=0.05
GRAPHRAG_LOCAL_TEXT_UNIT_PROP=0.92
GRAPHRAG_LOCAL_TOP_K_MAPPED_ENTITIES=8
GRAPHRAG_LOCAL_TOP_K_RELATIONSHIPS=8
GRAPHRAG_LOCAL_MAX_CONTEXT_TOKENS=3000
GRAPHRAG_LOCAL_INCLUDE_RELATIONSHIP_WEIGHT=true
