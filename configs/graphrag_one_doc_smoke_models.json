{
  "output_path": "results/experiments/graphrag_one_doc_smoke_models/matrix_summary.json",
  "report_path": "results/experiments/graphrag_one_doc_smoke_models/model_comparison_report.md",
  "defaults": {
    "models": {
      "backend": "local_openai",
      "base_url": "http://127.0.0.1:8001/v1",
      "api_key": "local-dev-key",
      "auto_download": true,
      "generation_model": "mistralai/Mistral-7B-Instruct-v0.3",
      "embedding_model": "intfloat/e5-base-v2",
      "embedding_dimension": 768,
      "graphrag_index_model": "mistralai/Mistral-7B-Instruct-v0.3"
    },
    "dataset": {
      "type": "records_qa",
      "path": "data/smoke/graphrag_one_doc.jsonl",
      "name": "graphrag_one_doc_smoke",
      "limit": 1
    },
    "systems": [
      "graphrag"
    ],
    "chunking": {
      "strategy": "none",
      "chunk_size": 900,
      "chunk_overlap": 120
    },
    "graphrag": {
      "query_method": "local",
      "response_type": "Single sentence",
      "force_rebuild": true,
      "use_chunked_units": true,
      "index_method": "standard",
      "extract_graph_max_gleanings": 1
    }
  },
  "experiments": [
    {
      "id": "mistral_7b_one_doc",
      "enabled": true,
      "output_dir": "results/experiments/graphrag_one_doc_smoke_models/mistral_7b",
      "models": {
        "generation_model": "mistralai/Mistral-7B-Instruct-v0.3",
        "graphrag_index_model": "mistralai/Mistral-7B-Instruct-v0.3"
      }
    },
    {
      "id": "qwen_2_5_7b_one_doc",
      "enabled": true,
      "output_dir": "results/experiments/graphrag_one_doc_smoke_models/qwen_2_5_7b",
      "models": {
        "generation_model": "Qwen/Qwen2.5-7B-Instruct",
        "graphrag_index_model": "Qwen/Qwen2.5-7B-Instruct"
      }
    }
  ]
}
