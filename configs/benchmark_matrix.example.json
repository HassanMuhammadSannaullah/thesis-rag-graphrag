{
  "output_path": "results/experiments/example_matrix_summary.json",
  "defaults": {
    "models": {
      "backend": "local_openai",
      "base_url": "http://127.0.0.1:8001/v1",
      "api_key": "local-dev-key",
      "generation_model": "mistralai/Mistral-7B-Instruct-v0.3",
      "embedding_model": "intfloat/e5-base-v2",
      "graphrag_index_model": "mistralai/Mistral-7B-Instruct-v0.3"
    },
    "parallelism": {
      "embedding_concurrent_requests": 1,
      "retrieval_concurrent_requests": 1,
      "evaluation_concurrent_requests": 1,
      "graphrag_concurrent_requests": 1
    },
    "systems": ["baseline", "graphrag"],
    "chunking": {
      "strategy": "none",
      "chunk_size": 900,
      "chunk_overlap": 120
    },
    "baseline": {
      "top_k": 8,
      "dense_top_k": 30,
      "lexical_top_k": 30,
      "fusion_k": 60,
      "use_dense": true,
      "use_bm25": true,
      "use_reranker": true,
      "reranker_model": "cross-encoder/ms-marco-MiniLM-L-6-v2",
      "vector_backend": "faiss"
    },
    "graphrag": {
      "query_method": "local",
      "response_type": "Single sentence",
      "force_rebuild": false,
      "use_chunked_units": true
    }
  },
  "experiments": [
    {
      "id": "hybridqa_dev_20",
      "enabled": true,
      "output_dir": "results/experiments/hybridqa_dev_20",
      "dataset": {
        "type": "hybridqa",
        "split": "dev",
        "limit": 20,
        "max_passages": null
      }
    }
  ]
}
