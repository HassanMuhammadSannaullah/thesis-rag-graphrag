{
  "output_path": "results/experiments/hybridqa_full_3_models_smoke_local/matrix_summary.json",
  "report_path": "results/experiments/hybridqa_full_3_models_smoke_local/model_comparison_report.md",
  "defaults": {
    "models": {
      "backend": "local_openai",
      "base_url": "http://127.0.0.1:8001/v1",
      "api_key": "local-dev-key",
      "auto_download": false,
      "generation_model": "Qwen/Qwen2.5-7B-Instruct",
      "embedding_model": "intfloat/e5-base-v2",
      "embedding_dimension": 768,
      "graphrag_index_model": "Qwen/Qwen2.5-7B-Instruct"
    },
    "parallelism": {
      "embedding_concurrent_requests": 1,
      "retrieval_concurrent_requests": 1,
      "evaluation_concurrent_requests": 1,
      "graphrag_concurrent_requests": 1
    },
    "dataset": {
      "type": "hybridqa",
      "split": "dev",
      "limit": 1,
      "max_passages": 2,
      "prefer_raw": true,
      "auto_download": false
    },
    "systems": [
      "baseline",
      "graphrag"
    ],
    "chunking": {
      "strategy": "none",
      "chunk_size": 900,
      "chunk_overlap": 120
    },
    "baseline": {
      "top_k": 2,
      "dense_top_k": 4,
      "lexical_top_k": 4,
      "fusion_k": 20,
      "use_dense": true,
      "use_bm25": true,
      "use_reranker": true,
      "reranker_model": "cross-encoder/ms-marco-MiniLM-L-6-v2",
      "vector_backend": "faiss",
      "max_context_chars": 4000,
      "max_answer_tokens": 32
    },
    "graphrag": {
      "query_method": "local",
      "response_type": "Single sentence",
      "force_rebuild": true,
      "use_chunked_units": true,
      "index_method": "standard",
      "extract_graph_max_gleanings": 0,
      "max_context_tokens": 1500
    }
  },
  "experiments": [
    {
      "id": "qwen_2_5_7b_smoke1_local",
      "enabled": true,
      "output_dir": "results/experiments/hybridqa_full_3_models_smoke_local/qwen_2_5_7b",
      "models": {
        "generation_model": "Qwen/Qwen2.5-7B-Instruct",
        "graphrag_index_model": "Qwen/Qwen2.5-7B-Instruct"
      }
    },
    {
      "id": "mistral_7b_smoke1_local",
      "enabled": true,
      "output_dir": "results/experiments/hybridqa_full_3_models_smoke_local/mistral_7b",
      "models": {
        "generation_model": "mistralai/Mistral-7B-Instruct-v0.3",
        "graphrag_index_model": "mistralai/Mistral-7B-Instruct-v0.3"
      }
    },
    {
      "id": "zephyr_7b_beta_smoke1_local",
      "enabled": true,
      "output_dir": "results/experiments/hybridqa_full_3_models_smoke_local/zephyr_7b_beta",
      "models": {
        "generation_model": "HuggingFaceH4/zephyr-7b-beta",
        "graphrag_index_model": "HuggingFaceH4/zephyr-7b-beta"
      }
    }
  ]
}
