{
  "output_path": "results/experiments/hybridqa_smoke3_models/matrix_summary.json",
  "report_path": "results/experiments/hybridqa_smoke3_models/model_comparison_report.md",
  "defaults": {
    "models": {
      "backend": "local_openai",
      "base_url": "http://127.0.0.1:8001/v1",
      "api_key": "local-dev-key",
      "auto_download": true,
      "generation_model": "mistralai/Mistral-7B-Instruct-v0.3",
      "embedding_model": "intfloat/e5-base-v2",
      "embedding_dimension": 768,
      "graphrag_index_model": "mistralai/Mistral-7B-Instruct-v0.3"
    },
    "parallelism": {
      "embedding_concurrent_requests": 1,
      "retrieval_concurrent_requests": 1,
      "evaluation_concurrent_requests": 1,
      "graphrag_concurrent_requests": 1
    },
    "dataset": {
      "type": "hybridqa",
      "split": "dev",
      "limit": 3,
      "max_passages": null,
      "prefer_raw": true
    },
    "systems": ["baseline", "graphrag"],
    "chunking": {
      "strategy": "none",
      "chunk_size": 900,
      "chunk_overlap": 120
    },
    "baseline": {
      "top_k": 8,
      "dense_top_k": 30,
      "lexical_top_k": 30,
      "fusion_k": 60,
      "use_dense": true,
      "use_bm25": true,
      "use_reranker": true,
      "reranker_model": "cross-encoder/ms-marco-MiniLM-L-6-v2",
      "vector_backend": "faiss",
      "max_context_chars": 16000,
      "max_answer_tokens": 128
    },
    "graphrag": {
      "query_method": "local",
      "response_type": "Single sentence",
      "force_rebuild": false,
      "use_chunked_units": true,
      "index_method": "standard"
    }
  },
  "experiments": [
    {
      "id": "mistral_7b_smoke3",
      "enabled": true,
      "output_dir": "results/experiments/hybridqa_smoke3_models/mistral_7b",
      "models": {
        "generation_model": "mistralai/Mistral-7B-Instruct-v0.3",
        "graphrag_index_model": "mistralai/Mistral-7B-Instruct-v0.3"
      },
      "graphrag": {
        "force_rebuild": false
      }
    },
    {
      "id": "qwen_2_5_7b_smoke3",
      "enabled": true,
      "output_dir": "results/experiments/hybridqa_smoke3_models/qwen_2_5_7b",
      "models": {
        "generation_model": "Qwen/Qwen2.5-7B-Instruct",
        "graphrag_index_model": "Qwen/Qwen2.5-7B-Instruct"
      },
      "graphrag": {
        "force_rebuild": true
      }
    }
  ]
}
