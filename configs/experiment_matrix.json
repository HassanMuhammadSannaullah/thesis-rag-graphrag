{
  "version": "2.0",
  "description": "Thesis experiment matrix: HybridQA baseline vs GraphRAG comparison with 50-question run.",
  "defaults": {
    "python": "python",
    "stop_on_failure": true,
    "output_root": "results/experiments/hybridqa_comparison",
    "env": {
      "EVALUATION_FRAMEWORK": "classic",
      "MODEL_BACKEND": "local_openai",
      "LOCAL_GENERATION_MODEL": "mistralai/Mistral-7B-Instruct-v0.3",
      "LOCAL_GRAPHRAG_INDEX_MODEL": "mistralai/Mistral-7B-Instruct-v0.3",
      "LOCAL_EMBEDDING_MODEL": "intfloat/e5-base-v2"
    }
  },
  "experiments": [
    {
      "id": "hybridqa_50_questions_mistral7b_e5base_full",
      "enabled": false,
      "script": "scripts/11_run_hybridqa_proper_compare.py",
      "args": {
        "split": "dev",
        "systems": "baseline,graphrag",
        "question-limit": 50,
        "graphrag-query-method": "local",
        "baseline-top-k": 8,
        "baseline-max-context-chars": 16000,
        "baseline-max-answer-tokens": 128,
        "force-query": false,
        "force-reindex": false
      },
      "notes": "Full 50-question HybridQA comparison using local Mistral 7B for both baseline RAG answering and GraphRAG indexing/querying."
    },
    {
      "id": "hybridqa_20_questions_mistral7b_e5base_tuned",
      "enabled": true,
      "script": "scripts/11_run_hybridqa_proper_compare.py",
      "args": {
        "split": "dev",
        "systems": "baseline,graphrag",
        "question-limit": 20,
        "graphrag-query-method": "local",
        "baseline-top-k": 8,
        "baseline-max-context-chars": 16000,
        "baseline-max-answer-tokens": 128,
        "force-query": true,
        "force-reindex": true
      },
      "notes": "Quick tuned validation run on 20 dev questions. Forces fresh query + reindex so the run reflects current tuning and avoids stale 50-question caches."
    }
  ]
}
